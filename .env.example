# LLM Provider: "gemini" (default) or "nvidia"
LLM_PROVIDER=gemini

# Google Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_key_here

# Google Genai
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# NVIDIA (required when LLM_PROVIDER=nvidia)
# NVIDIA_API_KEY=nvapi-your_key_here
# NVIDIA_BASE_URL=http://localhost:8000/v1  # optional, for self-hosted NIM
# DEFAULT_MODEL=meta/llama-3.3-70b-instruct  # optional, overrides provider default

# Localization
DEFAULT_TIMEZONE=Europe/Berlin

# WhatsApp agent (optional — only required when running whatsapp-agent)
# WHATSAPP_SESSION_DB=data/whatsapp_session.db
# WHATSAPP_STORAGE_PATH=data/whatsapp_users.json
# Phone number used for pairing code login (recommended over QR scan).
# Format: +<country code><number>, e.g. +491729975477
# If unset, falls back to QR code on first run.
# WHATSAPP_PHONE_NUMBER=+491234567890

# LangSmith (optional, uncomment to enable tracing)
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# LANGSMITH_API_KEY="your_key_here"
# LANGSMITH_PROJECT="Projct-Name"

{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "WebFetch(domain:github.com)",
      "Bash(pre-commit run:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__github__get_file_contents",
      "Bash(pytest:*)",
      "Bash(mypy:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(python -c \":*)",
      "mcp__github__list_pull_requests",
      "mcp__github__merge_pull_request",
      "mcp__railway-mcp-server__list-projects",
      "mcp__railway-mcp-server__list-services",
      "mcp__railway-mcp-server__list-variables",
      "mcp__railway-mcp-server__check-railway-status",
      "mcp__railway-mcp-server__link-environment",
      "mcp__railway-mcp-server__list-deployments",
      "mcp__railway-mcp-server__link-service",
      "mcp__railway-mcp-server__set-variables",
      "mcp__railway-mcp-server__deploy",
      "mcp__railway-mcp-server__get-logs"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "github"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/padel-agent/.claude/hooks/pre-tool-use/ruff-gate.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/padel-agent/.claude/hooks/notification/skill-suggester.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/padel-agent/.claude/hooks/user-prompt-submit/skill-activation-prompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspaces/padel-agent/.claude/hooks/post-tool-use/post-tool-use-tracker.sh"
          }
        ]
      }
    ]
  }
}
